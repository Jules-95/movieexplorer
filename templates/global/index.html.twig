{% extends 'base.html.twig' %}

{% block title %}Accueil - Movie Explorer{% endblock %}

{% block body %}
<main class="min-h-screen bg-gray-950 flex flex-col items-center justify-center text-center px-4">
    <div class="max-w-xl">
        <h1 class="text-4xl font-bold text-white mb-4">{{ message }}</h1>
        <p class="text-gray-400 text-lg mb-8"> Retrouvez vos films préférés.</p>
        <a href="{{ path('films') }}" class="inline-block bg-white text-gray-900 font-semibold px-6 py-3 rounded-full hover:bg-gray-200 transition-colors">
            Voir les films
        </a>
    </div>
</main>
{% endblock %}
